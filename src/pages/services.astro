---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Cutona - Smart Solutions | Cutona" currentPage="services">
  <main>
    <!-- =========================
Service section (Customized for Cutona)
===========================-->
<section
  class="pt-14 pb-14 md:pt-16 md:pb-16 lg:pt-[120px] lg:pb-[120px] xl:pt-[160px] xl:pb-[160px]"
>
  <div class="main-container">
    <div class="mb-[70px] space-y-3 text-center">
      <span data-ns-animate data-delay="0.2" class="badge badge-green"
        >Our Cutona Solutions</span
      >
      <h2
        data-ns-animate
        data-delay="0.3"
        class="mx-auto max-w-[600px] xl:max-w-[878px]"
      >
        Innovative tech projects by <span class="text-primary-500"
          >Cutona</span
        >
      </h2>
      <p
        data-ns-animate
        data-delay="0.4"
        class="mx-auto max-w-[500px] xl:max-w-[700px]"
      >
        Explore our specialized software and flagship hardware projects, all
        branded with the Cutona name.
      </p>
    </div>
    <div class="grid grid-cols-12 gap-y-12 md:gap-14 lg:gap-[72px]">
      <!-- Hotel Booking Software (using ns-shape-2) -->
      <div
        data-ns-animate
        data-delay="0.5"
        class="col-span-12 md:col-span-6 lg:col-span-4"
