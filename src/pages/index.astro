---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Smart Solutions - Home | Cutona" currentPage="home">
  <main>
    <!-- =========================
Hero section
===========================-->
    <section class="overflow-hidden pt-[115px] pb-[97px]">
      <div class="mx-auto max-w-[1365px]">
        <div class="relative">
          <!-- hero bg  -->
          <figure
            class="absolute -top-5 left-[50%] -z-10 h-full w-full max-w-[1365px] translate-x-[-50%] animate-pulse overflow-hidden"
          >
            <img
              src="images/ns-img-187.svg"
              alt="Decorative background pattern"
              class="size-full object-cover dark:hidden"
            />
            <img
              src="images/ns-img-dark-126.svg"
              alt="Decorative background pattern"
              class="hidden size-full object-cover dark:inline-block"
            />
          </figure>

          <div class="main-container">
            <div
              class="flex flex-col items-start justify-between gap-12 pt-4 pb-[110px] lg:flex-row lg:pt-[200px] xl:gap-0"
            >
              <!-- hero content  -->
              <div
                class="w-full space-y-7 text-center md:text-left lg:max-w-[490px] lg:space-y-14 xl:max-w-[629px]"
              >
                <!-- heading text  -->
                <div class="space-y-4">
                  <h1 data-ns-animate data-delay="0.2">
                    Software & products that power real businesses
                  </h1>
                  <p data-ns-animate data-delay="0.3">
                    Cutona delivers purpose-built software solutions — from GST billing and hotel booking to IoT management and quiz platforms — designed to replace manual work, reduce overhead, and scale with your business.
                  </p>
                </div>
                <!-- heading btn  -->
                <div data-ns-animate data-delay="0.4" class="w-full md:w-auto">
                  <a
                    href="/contact"
                    rel="noopener noreferrer"
                    class="btn btn-lg btn-primary hover:btn-secondary dark:hover:btn-accent w-[90%] md:w-auto"
                    aria-label="Book a free demo to see Cutona products in action"
                  >
                    <span>Book a free demo</span>
                  </a>
                </div>
              </div>

              <div class="relative" aria-hidden="true">
                <!-- income   -->
                <div
                  data-ns-animate
                  data-delay="0.3"
                  class="absolute top-[-5px] -left-0.5 md:left-[41px] lg:-top-[110px] lg:-left-[120px] xl:left-[-111px] 2xl:-left-[120px]"
                >
                  <div
                    class="dark:bg-background-8 max-w-[103px] flex-1 space-y-2 rounded-xl bg-white p-4 text-left"
                  >
                    <div
                      class="text-tagline-2 text-secondary dark:text-accent flex items-center justify-start gap-2"
                    >
                      <span
                        class="bg-ns-red flex size-[18px] items-center justify-center rounded-full p-1"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="8"
                          height="9"
                          viewBox="0 0 8 9"
                          fill="none"
                          aria-hidden="true"
                          focusable="false"
                        >
                          <path
                            d="M7.8842 4.49692C7.81538 4.42054 7.72089 4.37564 7.62101 4.37185C7.51393 4.36976 7.41095 4.41514 7.33717 4.49692L4.39555 7.59633L4.39555 0.407818C4.39277 0.18381 4.2211 0.00292873 4.0085 0C3.79589 0.00292873 3.62422 0.18381 3.62144 0.407818L3.62144 7.59633L0.679823 4.49692C0.581182 4.39007 0.435935 4.34679 0.298794 4.38337C0.161654 4.41996 0.0534544 4.53085 0.0149541 4.67428C-0.0235462 4.81771 0.0135021 4.97189 0.112143 5.07873L3.72465 8.88503C3.87798 9.03832 4.11836 9.03832 4.27169 8.88503L7.8842 5.07873C7.95828 5.00206 8 4.89724 8 4.78783C8 4.67841 7.95828 4.57359 7.8842 4.49692Z"
                            class="fill-secondary dark:fill-accent"></path>
                        </svg>
                      </span>
                      Revenue
                    </div>
                    <div
                      class="dark:text-accent flex items-center text-lg leading-[1.5] font-medium"
                    >
                      $
                      <span
                        data-counter
                        data-number="48000"
                        data-speed="2000"
                        data-interval="200"
                        data-rooms="5"
                        data-height-space="2.5">48,000</span
                      >
                    </div>
                  </div>
                </div>

                <!-- avatar img  -->
                <figure
                  data-ns-animate
                  data-delay="0.4"
                  class="absolute top-[117px] left-[-5px] z-[1] max-w-[96px] overflow-hidden rounded-xl md:left-[23px] md:max-w-[119px] lg:top-2.5 lg:left-[-222px] lg:max-w-[104px] xl:top-6 xl:left-[-203px] xl:max-w-[119px] 2xl:top-2.5 2xl:-left-[132px]"
                >
                  <div class="dark:bg-background-6 rounded-xl bg-white p-6">
                    <img
                      class="inline-block size-16 h-auto rounded-full bg-linear-[156deg,_#FFF_32.92%,_#C6F56F_91%] sm:size-14"
                      src="images/ns-avatar-9.png"
                      alt="Avatar 1"
                    />
                  </div>
                </figure>

                <!-- transfer success  -->
                <figure
                  data-ns-animate
                  data-delay="0.6"
                  class="absolute top-[250px] left-[-5px] z-[1] max-w-[153px] overflow-hidden rounded-xl md:top-[271px] md:left-[9px] md:max-w-[153px] lg:top-40 lg:left-[-223px] xl:left-[-206px] 2xl:-left-[151px]"
                >
                  <div
                    class="bg-secondary dark:bg-background-6 flex flex-col items-center gap-1 rounded-xl p-4"
                  >
                    <span>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="37"
                        height="36"
                        viewBox="0 0 37 36"
                        fill="none"
                        aria-hidden="true"
                        focusable="false"
                      >
                        <path
                          d="M13.0703 18.0011L16.6853 21.6311L23.9303 14.3711"
                          stroke="#C6F56F"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"></path>
                        <path
                          d="M16.6253 3.67547C17.6603 2.79047 19.3553 2.79047 20.4053 3.67547L22.7753 5.71547C23.2253 6.10547 24.0653 6.42047 24.6653 6.42047H27.2153C28.8053 6.42047 30.1103 7.72547 30.1103 9.31547V11.8655C30.1103 12.4505 30.4253 13.3055 30.8153 13.7555L32.8553 16.1255C33.7403 17.1605 33.7403 18.8555 32.8553 19.9055L30.8153 22.2755C30.4253 22.7255 30.1103 23.5655 30.1103 24.1655V26.7155C30.1103 28.3055 28.8053 29.6105 27.2153 29.6105H24.6653C24.0803 29.6105 23.2253 29.9255 22.7753 30.3155L20.4053 32.3555C19.3703 33.2405 17.6753 33.2405 16.6253 32.3555L14.2553 30.3155C13.8053 29.9255 12.9653 29.6105 12.3653 29.6105H9.77031C8.18031 29.6105 6.87531 28.3055 6.87531 26.7155V24.1505C6.87531 23.5655 6.56031 22.7255 6.18531 22.2755L4.16031 19.8905C3.29031 18.8555 3.29031 17.1755 4.16031 16.1405L6.18531 13.7555C6.56031 13.3055 6.87531 12.4655 6.87531 11.8805V9.30047C6.87531 7.71047 8.18031 6.40547 9.77031 6.40547H12.3653C12.9503 6.40547 13.8053 6.09047 14.2553 5.70047L16.6253 3.67547Z"
                          stroke="#C6F56F"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"></path>
                      </svg>
                    </span>
                    <span class="dark:text-accent text-white">
                      Invoice sent!
                    </span>
                  </div>
                </figure>

                <!-- main img  -->
                <figure
                  data-ns-animate
                  data-delay="0.6"
                  class="dark:bg-background-9 relative top-[100px] left-[30px] w-full max-w-[280px] rounded-xl bg-white p-2.5 md:left-[160px] md:max-w-[403px] lg:top-[3px] lg:left-[-109px] lg:max-w-[275px] xl:left-[-107px] xl:max-w-[408px] 2xl:left-[-3px] 2xl:max-w-[408px]"
                >
                  <img
                    src="images/ns-img-188.png"
                    alt="Cutona software dashboard interface"
                    class="rounded-xl dark:hidden"
                  />
                  <img
                    src="images/ns-img-dark-127.png"
                    alt="Cutona software dashboard interface"
                    class="hidden rounded-xl dark:block"
                  />
                </figure>

                <!-- expenses div  -->
                <div
                  data-ns-animate
                  data-delay="0.4"
                  class="absolute top-[-4px] right-[-104px] w-full max-w-[200px] max-[376px]:top-[-6px] max-[376px]:right-[-43px] sm:max-w-[333px] md:top-[-6px] md:right-[-85px] lg:top-[-111px] lg:right-[5px] xl:top-[-111px] xl:right-[75px]"
                >
                  <div
                    class="dark:bg-background-8 flex-1 space-y-2 rounded-xl bg-white p-4 text-left"
                  >
                    <div
                      class="text-tagline-2 text-secondary dark:text-accent flex items-center justify-start gap-2"
                    >
                      <span
                        class="bg-ns-green dark:bg-background-9 flex size-[18px] items-center justify-center rounded-full p-1"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="8"
                          height="9"
                          viewBox="0 0 8 9"
                          fill="none"
                          aria-hidden="true"
                          focusable="false"
                          class="fill-secondary dark:fill-accent"
                        >
                          <path
                            d="M7.8842 4.50308C7.81538 4.57946 7.72089 4.62436 7.62101 4.62815C7.51393 4.63024 7.41095 4.58486 7.33717 4.50308L4.39555 1.40367L4.39555 8.59218C4.39277 8.81619 4.2211 8.99707 4.0085 9C3.79589 8.99707 3.62422 8.81619 3.62144 8.59218L3.62144 1.40367L0.679823 4.50308C0.581182 4.60993 0.435935 4.65321 0.298794 4.61663C0.161654 4.58004 0.0534544 4.46915 0.0149541 4.32572C-0.0235462 4.18229 0.0135021 4.02811 0.112143 3.92127L3.72465 0.114967C3.87798 -0.0383222 4.11836 -0.0383222 4.27169 0.114967L7.8842 3.92127C7.95828 3.99794 8 4.10276 8 4.21217C8 4.32159 7.95828 4.42641 7.8842 4.50308Z"
                          ></path>
                        </svg>
                      </span>
                      Savings
                    </div>
                    <div
                      class="text-secondary dark:text-accent flex items-center text-lg leading-[1.5] font-medium"
                    >
                      $
                      <span
                        data-counter
                        data-number="2321"
                        data-speed="2000"
                        data-interval="200"
                        data-rooms="4"
                        data-height-space="2.5">2,321</span
                      >
                    </div>
                  </div>
                </div>

                <!-- nearest img  -->
                <figure
                  data-ns-animate
                  data-delay="0.5"
                  data-direction="right"
                  class="shadow-2 absolute hidden max-w-[231px] overflow-hidden rounded-[10px] md:top-[52px] md:right-[-207px] md:block lg:top-[-12px] lg:right-1.5 xl:top-[-4px] xl:right-[76px] 2xl:-top-12 2xl:right-[-53px]"
                >
                  <img
                    src="images/ns-img-189.svg"
                    alt="Cutona product interface element"
                    class="size-full object-cover dark:hidden"
                  />
                  <img
                    src="images/ns-img-dark-128.svg"
                    alt="Cutona product interface element"
                    class="hidden size-full object-cover dark:block"
                  />
                </figure>

                <!-- customers img  -->
                <figure
                  data-ns-animate
                  data-delay="0.6"
                  data-direction="right"
                  data-offset="80"
                  class="shadow-2 absolute top-[164px] right-[-83px] w-full max-w-[222px] overflow-hidden rounded-[10px] max-[376px]:right-[-67px] md:top-[287px] md:right-[-247px] lg:top-[129px] lg:right-[8px] xl:top-[187px] 2xl:top-[189px] 2xl:right-[-98px]"
                >
                  <img
                    src="images/ns-img-190.png"
                    alt="Cutona customer metrics"
                    class="size-full object-cover dark:hidden"
                  />
                  <img
                    src="images/ns-img-dark-129.png"
                    alt="Cutona customer metrics"
                    class="hidden size-full object-cover dark:block"
                  />
                </figure>

                <!-- credit limit img  -->
                <figure
                  data-ns-animate
                  data-delay="0.7"
                  data-direction="right"
                  data-offset="120"
                  data-progress-item
                  data-progress-value="88"
                  data-progress-duration="2.5"
                  class="shadow-2 absolute top-[234px] right-[-88px] w-full max-w-[189px] max-[376px]:right-[-71px] md:top-[366px] md:right-[-313px] md:max-w-[288px] lg:top-[206px] lg:right-[6px] lg:max-w-[225px] xl:top-[266px] xl:right-[7px] xl:max-w-[288px] 2xl:right-[-167px]"
                >
                  <figure
                    class="finance-intro-badge dark:bg-background-6 space-y-2 rounded-xl bg-white p-4"
                  >
                    <figcaption class="flex justify-between gap-2">
                      <span class="text-tagline-1 dark:text-accent font-normal">
                        Clients served
                      </span>
                      <span
                        class="text-secondary dark:text-accent flex items-center text-lg leading-[1.5] font-medium"
                        >
                        <span
                          data-counter
                          data-number="10000"
                          data-speed="2000"
                          data-interval="200"
                          data-rooms="5"
                          data-height-space="2.5">10,000</span
                        >+
                      </span>
                    </figcaption>
                    <div
                      class="flex items-center justify-between gap-1"
                      role="status"
                      aria-label="Client satisfaction rate"
                    >
                      <span
                        class="bg-secondary dark:bg-background-2 relative inline-block h-1.5 w-full max-w-[229px] rounded-full"
                      >
                        <span
                          class="bg-ns-green absolute top-0 left-0 h-full w-0 rounded-full"
                          data-progress-bar></span>
                      </span>
                      <span
                        data-progress-text
                        class="text-tagline-3 dark:text-accent font-normal"
                        >88%</span
                      >
                    </div>
                  </figure>
                </figure>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- =========================
Team section
===========================-->
    <section
      class="pb-[50px] md:pb-[80px] lg:pb-[100px]"
      aria-label="Team Introduction"
    >
      <div class="main-container">
        <div class="space-y-7 md:space-y-14">
          <h2
            data-ns-animate
            data-delay="0.1"
            class="split-text-team-title text-center"
          >
            From intelligent billing software to scalable room booking systems, every Cutona product is engineered to eliminate complexity and put control back in your hands.
          </h2>

          <div data-ns-animate data-delay="0.3" class="text-center">
            <a
              href="/team"
              rel="noopener noreferrer"
              class="btn btn-primary btn-md hover:btn-secondary dark:hover:btn-accent w-[85%] md:w-auto"
              aria-label="Meet the Cutona team"
            >
              <span>Meet the Cutona team</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- =========================
Solutions Section - Cutona Products & Projects
===========================-->
    <section
      class="pt-14 pb-14 md:pt-16 md:pb-16 lg:pt-[120px] lg:pb-[120px] xl:pt-[160px] xl:pb-[160px] bg-background-2 dark:bg-background-5"
    >
      <div class="main-container">
        <div class="mb-[70px] space-y-3 text-center">
          <span data-ns-animate data-delay="0.2" class="badge badge-green"
            >Our Products</span
          >
          <h2
            data-ns-animate
            data-delay="0.3"
            class="mx-auto max-w-[600px] xl:max-w-[878px]"
          >
            Built by <span class="text-primary-500">Cutona</span>, trusted by businesses
          </h2>
          <p
            data-ns-animate
            data-delay="0.4"
            class="mx-auto max-w-[500px] xl:max-w-[700px]"
          >
            Explore our suite of ready-to-deploy software products and next-generation hardware — all designed, developed, and supported under the Cutona brand.
          </p>
        </div>
        <div class="grid grid-cols-12 gap-y-12 md:gap-14 lg:gap-[72px]">
          <!-- Hotel Booking Software -->
          <div
            data-ns-animate
            data-delay="0.5"
            class="col-span-12 md:col-span-6 lg:col-span-4"
          >
            <div class="space-y-6">
              <div
                class="flex items-center justify-center md:items-start md:justify-start"
              >
                <span
                  class="ns-shape-2 text-secondary dark:text-accent text-[52px]"
                ></span>
              </div>
              <div class="space-y-2 text-center md:text-left">
                <h3 class="text-heading-5">Cutona Hotel Booking</h3>
                <p>
                  A full-featured hotel reservation platform — manage room availability, guest check-ins, rate plans, and online bookings from one centralized dashboard.
                </p>
              </div>
              <div class="text-center md:text-left">
                <div
                  class="btn-v3-lg btn-v3-white border-secondary/20 mx-auto border sm:mx-0 w-fit cursor-pointer rounded-2xl px-1 py-1"
                  aria-label="Read more about Hotel Booking"
                  data-button-v3
                >
                  <a href="/projects/cutona-hotel-booking" class="block">
                    <div class="flex items-center gap-x-4">
                      <span
                        class="relative z-20 flex shrink-0 items-center justify-center overflow-hidden rounded-[13px] p-2.5 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]"
                        data-button-v3-icon
                        aria-hidden="true"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6">
                          <path d="M11 5H13V7H11V5Z"></path><path d="M5 5H7V7H5V5Z"></path>
                          <path d="M14 8H16V10H14V8Z"></path><path d="M8 8H10V10H8V8Z"></path>
                          <path d="M17 11H19V13H17V11Z"></path><path d="M11 11H13V13H11V11Z"></path>
                          <path d="M14 14H16V16H14V14Z"></path><path d="M8 14H10V16H8V14Z"></path>
                          <path d="M11 17H13V19H11V17Z"></path><path d="M5 17H7V19H5V17Z"></path>
                        </svg>
                      </span>
                      <span class="shrink-0 pr-4 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] first-letter:uppercase" data-button-v3-text aria-hidden="true">
                        View product
                      </span>
                    </div>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Billing Software -->
          <div
            data-ns-animate
            data-delay="0.6"
            class="col-span-12 md:col-span-6 lg:col-span-4"
          >
            <div class="space-y-6">
              <div
                class="flex items-center justify-center md:items-start md:justify-start"
              >
                <span
                  class="ns-shape-3 text-secondary dark:text-accent text-[52px]"
                ></span>
              </div>
              <div class="space-y-2 text-center md:text-left">
                <h3 class="text-heading-5">Cutona Billing</h3>
                <p>
                  Automate your entire billing workflow — generate invoices, track payments, manage tax compliance, and get financial reports without touching a spreadsheet.
                </p>
              </div>
              <div class="text-center md:text-left">
                <div
                  class="btn-v3-lg btn-v3-white border-secondary/20 mx-auto border sm:mx-0 w-fit cursor-pointer rounded-2xl px-1 py-1"
                  aria-label="Read more about Billing"
                  data-button-v3
                >
                  <a href="/projects/cutona-billing" class="block">
                    <div class="flex items-center gap-x-4">
                      <span class="relative z-20 flex shrink-0 items-center justify-center overflow-hidden rounded-[13px] p-2.5 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]" data-button-v3-icon aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6">
                          <path d="M11 5H13V7H11V5Z"></path><path d="M5 5H7V7H5V5Z"></path>
                          <path d="M14 8H16V10H14V8Z"></path><path d="M8 8H10V10H8V8Z"></path>
                          <path d="M17 11H19V13H17V11Z"></path><path d="M11 11H13V13H11V11Z"></path>
                          <path d="M14 14H16V16H14V14Z"></path><path d="M8 14H10V16H8V14Z"></path>
                          <path d="M11 17H13V19H11V17Z"></path><path d="M5 17H7V19H5V17Z"></path>
                        </svg>
                      </span>
                      <span class="shrink-0 pr-4 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] first-letter:uppercase" data-button-v3-text aria-hidden="true">View product</span>
                    </div>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Drone Project -->
          <div
            data-ns-animate
            data-delay="0.7"
            class="col-span-12 md:col-span-6 lg:col-span-4"
          >
            <div class="space-y-6">
              <div class="flex items-center justify-center md:items-start md:justify-start">
                <span class="ns-shape-4 text-secondary dark:text-accent text-[52px]"></span>
              </div>
              <div class="space-y-2 text-center md:text-left">
                <h3 class="text-heading-5">Cutona Drone</h3>
                <p>
                  A next-generation autonomous drone platform engineered for aerial surveillance, logistics delivery, precision agriculture, and advanced reconnaissance operations.
                </p>
              </div>
              <div class="text-center md:text-left">
                <div class="btn-v3-lg btn-v3-white border-secondary/20 mx-auto border sm:mx-0 w-fit cursor-pointer rounded-2xl px-1 py-1" aria-label="Read more about Drone" data-button-v3>
                  <a href="/projects/cutona-drone" class="block">
                    <div class="flex items-center gap-x-4">
                      <span class="relative z-20 flex shrink-0 items-center justify-center overflow-hidden rounded-[13px] p-2.5 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]" data-button-v3-icon aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6">
                          <path d="M11 5H13V7H11V5Z"></path><path d="M5 5H7V7H5V5Z"></path>
                          <path d="M14 8H16V10H14V8Z"></path><path d="M8 8H10V10H8V8Z"></path>
                          <path d="M17 11H19V13H17V11Z"></path><path d="M11 11H13V13H11V11Z"></path>
                          <path d="M14 14H16V16H14V14Z"></path><path d="M8 14H10V16H8V14Z"></path>
                          <path d="M11 17H13V19H11V17Z"></path><path d="M5 17H7V19H5V17Z"></path>
                        </svg>
                      </span>
                      <span class="shrink-0 pr-4 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] first-letter:uppercase" data-button-v3-text aria-hidden="true">View product</span>
                    </div>
                  </a>
                </div>
              </div>
