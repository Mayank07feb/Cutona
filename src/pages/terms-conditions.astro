---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Smart Solutions - Terms & Conditions | Cutona"
  currentPage="terms-conditions"
>
  <main>
    <!-- ===============
  Terms & Conditions
  ==================== -->

    <section
      class="pt-[120px] pb-14 md:pb-16 lg:pt-[160px] lg:pb-[88px] xl:pb-[200px]"
    >
      <div class="main-container">
        <div data-ns-animate data-delay="0.3" class="space-y-3">
          <h2>Terms & conditions</h2>
          <div class="space-y-7">
            <p>
              This site, Cutona.com (hereafter referred to as Cutona, site, or
              website) is owned and operated by Cutona Technologies LLC
              (hereafter referred to as Cutona, we, or company).
            </p>
            <p>
              Please carefully read, review, and understand our Terms and
              Conditions before using any services or products from Cutona.com.
              Your access to and use of this website and its products indicate
              that you accept and agree to be bound by these terms and
              conditions.
            </p>
            <p>
              If you do not agree with these terms, you should leave the site
              immediately and not use any of the materials or services available
              here.
            </p>
          </div>
        </div>

        <article class="terms-conditions-body">
          <div data-ns-animate data-delay="0.4" class="space-y-6">
            <h3>1. Limitation of liability</h3>
            <p>
              Under no circumstances shall Cutona be liable for any direct,
              indirect, incidental, special, or consequential damages, including
              but not limited to loss of data, profits, or business
              interruption, arising out of the use, or inability to use, the
              materials on this site, even if Cutona or an authorized
              representative has been advised of the possibility of such
              damages.
            </p>
            <p>
              If your use of materials from this site results in the need for
              servicing, repair, or correction of equipment or data, you assume
              all associated costs.
            </p>
          </div>
          <div data-ns-animate data-delay="0.5" class="space-y-6">
            <h3>2. License</h3>
            <p>
              Cutona services, platforms, and tools are provided under a
              commercial license agreement. Each subscription or license
              purchased includes access to updates and support for 365 days from
              the completion of the order.
            </p>
            <p>
              License activation is necessary to receive updates and premium
              support. You are not permitted to resell, redistribute, or offer
              Cutona products or services, modified or unmodified, without our
              written consent.
            </p>
          </div>
          <div data-ns-animate data-delay="0.6" class="space-y-6">
            <h3>3. Ownership and liability</h3>
            <p>
              All Cutona products, solutions, and materials remain the
              intellectual property of Cutona Technologies LLC. You may not
              claim ownership of our services, whether modified or unmodified.
            </p>

            <p>
              Our products and services are provided “as is” without warranty of
              any kind, expressed or implied. Cutona is not liable for any
              losses or damages resulting from the use or inability to use its
              products.
            </p>
            <p>
              User accounts and product licenses are
              <strong class="!text-secondary dark:!text-accent font-bold">
                non-transferable
              </strong>
              . For agencies and development partners: Please ensure your clients
              purchase their own licenses if they require direct support access.
            </p>
          </div>
          <div data-ns-animate data-delay="0.3" class="space-y-6">
            <h3>4. Refund policy</h3>
            <p>
              We believe you’ll love Cutona! Still, if you're not satisfied, we
              offer a 14-day no-questions-asked refund policy. Simply contact
              our support team within 14 days of your original purchase, and
              we’ll issue a full refund. We might ask for feedback to help us
              improve, but you’re under no obligation to share.
            </p>
          </div>

          <div data-ns-animate data-delay="0.4" class="mt-6">
            <!-- button v3 -->
            <div
              class="btn-v3-lg btn-v3-secondary w-fit cursor-pointer rounded-2xl px-1 py-1"
              aria-label="Learn more about refund policy"
              data-button-v3
            >
              <a href="/refund-policy" class="block">
                <div class="flex items-center gap-x-4">
                  <!-- icon   -->
                  <span
                    class="relative z-20 flex shrink-0 items-center justify-center overflow-hidden rounded-[13px] p-2.5 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]"
                    data-button-v3-icon
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      class="size-6"
                    >
                      <path d="M11 5H13V7H11V5Z"></path>
                      <path d="M5 5H7V7H5V5Z"></path>
                      <path d="M14 8H16V10H14V8Z"></path>
                      <path d="M8 8H10V10H8V8Z"></path>
                      <path d="M17 11H19V13H17V11Z"></path>
                      <path d="M11 11H13V13H11V11Z"></path>
                      <path d="M14 14H16V16H14V14Z"></path>
                      <path d="M8 14H10V16H8V14Z"></path>
                      <path d="M11 17H13V19H11V17Z"></path>
                      <path d="M5 17H7V19H5V17Z"></path>
                    </svg>
                  </span>
                  <!-- content  -->
                  <span
                    class="shrink-0 pr-4 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] first-letter:uppercase"
                    data-button-v3-text
                    aria-hidden="true"
                  >
                    Learn more about refund policy
                  </span>
                </div>
              </a>
            </div>
          </div>

          <div data-ns-animate data-delay="0.5" class="space-y-6">
            <h3>5. Warranty</h3>
            <p>
              Cutona services are provided without any warranty, either
              expressed or implied. We do not guarantee full compatibility with
              all browsers, devices, third-party plugins, or external systems.
              Before purchasing, you may review demos or contact our support
              team to verify compatibility with your setup.
            </p>
          </div>
          <div data-ns-animate data-delay="0.6" class="space-y-6">
            <h3>6. Account termination and suspension</h3>
            <p>
              Cutona reserves the right to suspend or terminate any user account
              without prior notice for reasons including but not limited to
            </p>
            <ul>
              <li>
                Abusive, defamatory, or malicious behavior towards Cutona staff
                or customers
              </li>
              <li>Spreading false information or misleading reviews</li>
              <li>
                Unauthorized resale, distribution, or promotion of competitor
                products
              </li>
              <li>
                Involvement in hacking, spamming, piracy, or illegal activities
              </li>
              <li>
                Security threats due to account compromise or unauthorized
                sharing
              </li>
            </ul>
          </div>
          <div data-ns-animate data-delay="0.3" class="space-y-6">
            <h3>7. Privacy policy</h3>
            <p>
              We value your privacy. Cutona does not sell, rent, or share your
              personal information with third parties. Your data is used solely
              for purposes such as
            </p>
            <ul>
              <li>Order processing</li>
              <li>Account management</li>
              <li>Billing disputes</li>
              <li>Fraudulent activities</li>
              <li>Legal compliance</li>
            </ul>

            <p>
              By using Cutona services, you consent to the collection and use of
              your data by our Privacy Policy.
            </p>
          </div>

          <div data-ns-animate data-delay="0.4" class="mt-6">
            <!-- button v3 -->
            <div
              class="btn-v3-lg btn-v3-secondary w-fit cursor-pointer rounded-2xl px-1 py-1"
              aria-label="Learn more about our privacy policy"
              data-button-v3
            >
              <a href="/privacy-policy" class="block">
                <div class="flex items-center gap-x-4">
                  <!-- icon   -->
                  <span
                    class="relative z-20 flex shrink-0 items-center justify-center overflow-hidden rounded-[13px] p-2.5 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]"
                    data-button-v3-icon
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      class="size-6"
                    >
                      <path d="M11 5H13V7H11V5Z"></path>
                      <path d="M5 5H7V7H5V5Z"></path>
                      <path d="M14 8H16V10H14V8Z"></path>
                      <path d="M8 8H10V10H8V8Z"></path>
                      <path d="M17 11H19V13H17V11Z"></path>
                      <path d="M11 11H13V13H11V11Z"></path>
                      <path d="M14 14H16V16H14V14Z"></path>
                      <path d="M8 14H10V16H8V14Z"></path>
                      <path d="M11 17H13V19H11V17Z"></path>
                      <path d="M5 17H7V19H5V17Z"></path>
                    </svg>
                  </span>
                  <!-- content  -->
                  <span
                    class="shrink-0 pr-4 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] first-letter:uppercase"
                    data-button-v3-text
                    aria-hidden="true"
                  >
                    Learn more about our privacy policy
                  </span>
                </div>
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- =========================
CTA v1 section
===========================-->
    <section
      class="py-[50px] md:py-20 lg:py-28"
      aria-label="Use Case Overview"
    >
      <div class="main-container">
        <div class="flex flex-col items-center justify-between lg:flex-row">
          <div
            class="w-full space-y-5 text-center max-[400px]:max-w-[300px] lg:max-w-[476px] lg:text-left xl:max-w-[650px]"
          >
            <span
              data-ns-animate
              data-delay="0.3"
              class="badge badge-green badge-yellow-v2">Get started</span
            >
            <div class="space-y-3">
              <h2
                data-ns-animate
                data-delay="0.4"
                class="text-secondary dark:text-accent text-heading-5 sm:text-heading-4 lg:text-heading-3 xl:text-heading-2"
              >
                Ready to start earning with Cutona?
                <span class="text-primary-500 hidden">Get started today</span>
              </h2>
              <p data-ns-animate data-delay="0.5">
                If you have any questions, feel free to reach out to our team.
              </p>
            </div>
          </div>

          <div
            class="w-full space-y-6 pt-[40px] sm:w-[80%] md:ml-0 md:w-[70%] lg:basis-[530px] lg:pt-[67px] xl:ml-[60px]"
          >
            <form
              data-ns-animate
              data-delay="0.6"
              action="#"
              method="post"
              class="flex flex-col items-center justify-start gap-5 sm:flex-row lg:gap-3"
            >
              <input
                type="email"
                name="email"
                id="userEmail-cta-v1"
                placeholder="Enter your email"
                required
                class="shadow-1 placeholder:text-secondary/50 border-stroke-1 dark:border-stroke-7 dark:placeholder:text-accent/60 focus:border-primary-600 dark:focus:border-primary-400 dark:text-accent h-12 w-full rounded-2xl border px-[18px] py-3 font-normal placeholder:font-normal focus:outline-none max-[376px]:w-full md:w-[61%] lg:max-w-[340px] xl:h-13 xl:w-[71%]"
              />

              <button
                type="submit"
                class="bg-primary-500 text-tagline-1 w-full cursor-pointer rounded-2xl px-1 py-1 font-normal text-white sm:w-auto"
                data-button-v3
              >
                <div class="flex items-center gap-x-4">
                  <!-- icon   -->
                  <span
                    class="fill-secondary relative z-20 flex size-10 items-center justify-center overflow-hidden rounded-[13px] bg-white transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] xl:size-11"
                    data-button-v3-icon
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      class="size-6"
                    >
                      <path d="M11 5H13V7H11V5Z"></path>
                      <path d="M5 5H7V7H5V5Z"></path>
                      <path d="M14 8H16V10H14V8Z"></path>
                      <path d="M8 8H10V10H8V8Z"></path>
                      <path d="M17 11H19V13H17V11Z"></path>
                      <path d="M11 11H13V13H11V11Z"></path>
                      <path d="M14 14H16V16H14V14Z"></path>
                      <path d="M8 14H10V16H8V14Z"></path>
                      <path d="M11 17H13V19H11V17Z"></path>
                      <path d="M5 17H7V19H5V17Z"></path>
                    </svg>
                  </span>
                  <!-- content  -->
                  <span
                    class="shrink-0 stroke-0 pr-4 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] first-letter:uppercase"
                    data-button-v3-text
                    aria-hidden="true"
                  >
                    Get started
                  </span>
                </div>
              </button>
            </form>
            <ul
              class="flex flex-row items-center justify-center gap-x-4 gap-y-5 sm:gap-x-6 sm:gap-y-0 lg:justify-start"
            >
              <li
                data-ns-animate
                data-delay="0.7"
                class="flex items-center justify-center gap-2"
              >
                <span
                  class="bg-secondary dark:bg-accent flex size-[18px] items-center justify-center rounded-full"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="10"
                    height="7"
                    viewBox="0 0 10 7"
                    fill="none"
                    aria-hidden="true"
                    class="dark:fill-secondary fill-white"
                  >
                    <path
                      d="M4.31661 6.75605L9.74905 1.42144C10.0836 1.0959 10.0836 0.569702 9.74905 0.244158C9.41446 -0.081386 8.87363 -0.081386 8.53904 0.244158L3.7116 4.99012L1.46096 2.78807C1.12636 2.46253 0.585538 2.46253 0.250945 2.78807C-0.0836483 3.11362 -0.0836483 3.63982 0.250945 3.96536L3.1066 6.75605C3.27347 6.91841 3.49253 7 3.7116 7C3.93067 7 4.14974 6.91841 4.31661 6.75605Z"
                    ></path>
                  </svg>
                </span>
                <p class="text-tagline-3 sm:text-tagline-2">
                  No credit card required
                </p>
              </li>
              <li
                data-ns-animate
                data-delay="0.8"
                class="flex items-center justify-center gap-2"
              >
                <span
                  class="bg-secondary dark:bg-accent flex size-[18px] items-center justify-center rounded-full"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="10"
                    height="7"
                    viewBox="0 0 10 7"
                    fill="none"
                    aria-hidden="true"
                    class="dark:fill-secondary fill-white"
                  >
                    <path
                      d="M4.31661 6.75605L9.74905 1.42144C10.0836 1.0959 10.0836 0.569702 9.74905 0.244158C9.41446 -0.081386 8.87363 -0.081386 8.53904 0.244158L3.7116 4.99012L1.46096 2.78807C1.12636 2.46253 0.585538 2.46253 0.250945 2.78807C-0.0836483 3.11362 -0.0836483 3.63982 0.250945 3.96536L3.1066 6.75605C3.27347 6.91841 3.49253 7 3.7116 7C3.93067 7 4.14974 6.91841 4.31661 6.75605Z"
                    ></path>
                  </svg>
                </span>
                <p class="text-tagline-3 sm:text-tagline-2">
                  14-Day free trial
                </p>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
